{
  "version": "agent-channels.v1",
  "channels": [
    {
      "id": "codex-account",
      "label": "Codex account CLI",
      "runner": "codex",
      "cli": "codex",
      "auth": { "type": "codex_account" },
      "auth_type": "codex_account",
      "account_login": true,
      "default_model": "gpt-5.5",
      "models": ["gpt-5.5", "gpt-5.3-codex-spark"]
    },
    {
      "id": "codex-token",
      "label": "Codex token proxy",
      "runner": "codex",
      "cli": "codex",
      "base_url": "https://subapi.elias.ccwu.cc",
      "auth": { "type": "openai_api_key_pool" },
      "auth_type": "openai_api_key_pool",
      "account_login": false,
      "default_model": "gpt-5.5",
      "models": ["gpt-5.5", "gpt-5.3-codex-spark"]
    },
    {
      "id": "claude",
      "label": "Claude Anthropic compatible",
      "runner": "claude",
      "cli": "claude",
      "base_url": "https://api-cc.freemodel.dev",
      "auth": { "type": "anthropic_api_key_pool" },
      "auth_type": "anthropic_api_key_pool",
      "account_login": false,
      "default_model": "claude-sonnet-4-6",
      "models": ["claude-opus-4-7", "claude-sonnet-4-6", "claude-haiku-4-5-20251001"]
    },
    {
      "id": "deepseek",
      "label": "DeepSeek Anthropic compatible",
      "runner": "claude",
      "cli": "claude",
      "base_url": "https://api.deepseek.com/anthropic",
      "auth": { "type": "anthropic_api_key_pool" },
      "auth_type": "anthropic_api_key_pool",
      "account_login": false,
      "default_model": "deepseek-v4-pro[1m]",
      "models": ["deepseek-v4-pro[1m]", "deepseek-v4-flash"]
    },
    {
      "id": "xiaomi-mimo",
      "label": "Xiaomi MiMo Anthropic compatible",
      "runner": "claude",
      "cli": "claude",
      "base_url": "https://token-plan-cn.xiaomimimo.com/anthropic",
      "auth": { "type": "anthropic_api_key_pool" },
      "auth_type": "anthropic_api_key_pool",
      "account_login": false,
      "default_model": "mimo-v2.5-pro",
      "models": ["mimo-v2.5-pro", "mimo-v2.5"]
    }
  ]
}
